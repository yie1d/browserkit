<!--
Template structure derived from cargo-about's MIT OR Apache-2.0 example.
https://github.com/EmbarkStudios/cargo-about
-->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>browserkit third-party licenses</title>
  <style>
    body { font-family: sans-serif; line-height: 1.4; margin: 2rem auto; max-width: 900px; padding: 0 1rem; }
    pre { max-height: 24rem; overflow: auto; white-space: pre-wrap; }
  </style>
</head>
<body>
  <h1>browserkit third-party licenses</h1>
  <p>This document lists licenses for Rust packages included in browserkit.</p>
  {{#each licenses}}
    {{#if first_of_kind}}<h2 id="{{id}}">{{name}}</h2>{{/if}}
    <h3>Used by</h3>
    <ul>
      {{#each used_by}}
      <li><a href="{{#if crate.repository}}{{crate.repository}}{{else}}https://crates.io/crates/{{crate.name}}{{/if}}">{{crate.name}} {{crate.version}}</a></li>
      {{/each}}
    </ul>
    <pre>{{text}}</pre>
  {{/each}}
</body>
</html>
